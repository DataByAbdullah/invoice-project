# ──────────────────────────────────────────────────────────────────────────────
# Invoice AI — Environment Variables
# Copy this file to docker/.env and fill in your real values.
#   cp docker/.env.example docker/.env
# docker/.env is gitignored and will NEVER be committed.
# ──────────────────────────────────────────────────────────────────────────────

# OpenAI — required for AI extraction, categorization, and monthly summaries
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Secret key for JWT signing — generate a strong random string (min 32 chars)
# Example: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-32-char-string-minimum
