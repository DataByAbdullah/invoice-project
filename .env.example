# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME="Invoice AI"
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://invoice_user:strongpassword@localhost:5432/invoice_ai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.0

# ─── OCR ──────────────────────────────────────────────────────────────────────
OCR_PROVIDER=tesseract           # tesseract | aws_textract | google_vision
TESSERACT_CMD=/usr/bin/tesseract

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local            # local | s3
UPLOAD_DIR=/tmp/invoice_uploads
MAX_UPLOAD_SIZE_MB=20
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/tiff

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=invoice_ai_secret_9XkL72pQmR4vT8zA3nY6bC1dE5fG0hJ
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Anomaly Detection ────────────────────────────────────────────────────────
ANOMALY_ZSCORE_THRESHOLD=2.5
DUPLICATE_SIMILARITY_THRESHOLD=0.85
